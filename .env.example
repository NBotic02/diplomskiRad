# =====================================================================
# Customer Support Platform — Environment Variables
# Copy this file to .env and fill in values before running docker compose.
# =====================================================================

# ---------------------------------------------------------------------
# PostgreSQL — admin credentials (used to bootstrap the DB on first run)
# ---------------------------------------------------------------------
POSTGRES_DB=customer_support
POSTGRES_ADMIN_USER=admin
POSTGRES_ADMIN_PASSWORD=changeme_admin

# ---------------------------------------------------------------------
# Per-service PostgreSQL users (one user per microservice — least privilege)
# Each user owns its own schema and can write to shared_types.outbox_events.
# ---------------------------------------------------------------------
CASE_DB_USER=case_service
CASE_DB_PASSWORD=changeme_case

EMPLOYEE_DB_USER=employee_service
EMPLOYEE_DB_PASSWORD=changeme_employee

NOTIFICATION_DB_USER=notification_service
NOTIFICATION_DB_PASSWORD=changeme_notification

ANALYTICS_DB_USER=analytics_service
ANALYTICS_DB_PASSWORD=changeme_analytics

# n8n stores its own metadata (workflows, executions) in its own schema
N8N_DB_USER=n8n_service
N8N_DB_PASSWORD=changeme_n8n

# ---------------------------------------------------------------------
# RabbitMQ — message broker for async service-to-service events
# ---------------------------------------------------------------------
RABBITMQ_USER=rabbit_admin
RABBITMQ_PASSWORD=changeme_rabbit

# ---------------------------------------------------------------------
# n8n — orchestration platform
# ---------------------------------------------------------------------
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_n8n_ui
# Must remain stable — used to encrypt credentials stored inside n8n.
# Losing this means losing access to all stored credentials.
N8N_ENCRYPTION_KEY=replace_with_32_char_random_string

# ---------------------------------------------------------------------
# Auth0 — identity provider (set these AFTER creating tenant in Auth0)
# Free tier: https://auth0.com/signup
# ---------------------------------------------------------------------
AUTH0_DOMAIN=your-tenant.eu.auth0.com
# API identifier (audience) — set when creating an API in Auth0 dashboard
AUTH0_AUDIENCE=https://customer-support-api
# Machine-to-machine credentials for n8n calling Spring Boot services
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=

# ---------------------------------------------------------------------
# AI usluge u n8n radnim tijekovima
# ---------------------------------------------------------------------
# Google Gemini — klasifikacija, vektorske ugradnje, generiranje odgovora
GEMINI_API_KEY=

# Pinecone — vektorska baza znanja
PINECONE_API_KEY=
PINECONE_INDEX_HOST=

# Cohere Rerank — drugi prolaz rangiranja
COHERE_API_KEY=

# ---------------------------------------------------------------------
# Gmail (App Password) — IMAP citanje i SMTP slanje
# ---------------------------------------------------------------------
GMAIL_USER=
GMAIL_APP_PASSWORD=
