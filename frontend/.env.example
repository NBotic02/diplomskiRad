# =====================================================================
# Frontend env vars. Vite ucitava sve varijable koje pocinju s VITE_
# pri buildu kao import.meta.env.VITE_*.
# Kopiraj ovu datoteku u .env i popuni stvarne vrijednosti.
# =====================================================================

# Auth0 — stvori SPA aplikaciju u Auth0 dashboardu.
VITE_AUTH0_DOMAIN=your-tenant.eu.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id

# Opcionalno. Kad je postavljen, getAccessTokenSilently vraca JWT
# potpisan za ovaj audience — sto je potrebno da Spring Boot servisi
# validiraju token u prod profilu. Ostavi prazno za test UI.
VITE_AUTH0_AUDIENCE=https://customer-support-api
